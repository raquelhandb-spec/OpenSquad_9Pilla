{
  "permissions": {
    "allow": [
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(curl:*)",
      "Bash(powershell:*)",
      "WebSearch",
      "WebFetch(domain:www.moneytimes.com.br)",
      "WebFetch(domain:www.riotimesonline.com)",
      "WebFetch(domain:www.bloomberg.com)",
      "WebFetch(domain:brapi.dev)",
      "WebFetch(domain:docs.google.com)",
      "WebFetch(domain:notion.so)",
      "Edit",
      "Read",
      "Write",
      "Glob",
      "Grep"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "canva",
    "gmail",
    "google-calendar"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit(file:*CLAUDE.md)",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "⚠️ ATENÇÃO: Você está editando CLAUDE.md! Este arquivo contém instruções críticas da 9Pilla e deve ser tratado com cuidado. Tem certeza que quer continuar?",
            "statusMessage": "Verificando edição de CLAUDE.md..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(git push)",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Verifica se o último commit segue o formato: 9P-XXX: Descrição (YYYY-MM-DD). Use $ARGUMENTS para obter detalhes.",
            "statusMessage": "Validando formato do commit..."
          }
        ]
      }
    ]
  },
  "customCommands": {
    "morning-call": "./.claude/commands/morning-call.md",
    "novo-ep": "./.claude/commands/novo-ep.md",
    "reel": "./.claude/commands/reel.md",
    "auditoria-ig": "./.claude/commands/auditoria-ig.md",
    "campanha": "./.claude/commands/campanha.md"
  }
}
