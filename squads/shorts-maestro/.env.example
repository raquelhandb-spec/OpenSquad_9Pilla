# 🚀 9PILLA SHORTS-MAESTRO ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your actual credentials

# ═══════════════════════════════════════════════════════════════
# 1. BRAPI — Brazilian Market Data API
# ═══════════════════════════════════════════════════════════════
# Obtém dados de mercado em tempo real (IBOV, PETR4, VALE3, etc)
# Signup: https://brapi.dev
BRAPI_API_KEY=tky3Vocipoj9ZocxEumbCe

# ═══════════════════════════════════════════════════════════════
# 2. OLLAMA — Local LLM for Script Generation
# ═══════════════════════════════════════════════════════════════
# Roda localmente no seu computador
# Setup: https://ollama.ai/download
# Comando para rodar: ollama serve
OLLAMA_BASE_URL=http://localhost:11434

# ═══════════════════════════════════════════════════════════════
# 3. ELEVENLABS — Voice Cloning & Text-to-Speech
# ═══════════════════════════════════════════════════════════════
# API Key para narração de scripts com sua voz
# Signup: https://elevenlabs.io
# 1. Clone sua voz: https://elevenlabs.io/voice-lab
# 2. Copie o Voice ID
ELEVENLABS_API_KEY=sk_2e12b95dc92a231055f4e9d4f275ae9fab83940d59b26a3e
ELEVENLABS_VOICE_ID=0r2zCQO0vO1jOfWbm7N7

# ⚠️ IMPORTANTE: Você precisa clonar sua voz!
# 1. Vá para: https://elevenlabs.io/voice-lab
# 2. Clique em "Clone Voice"
# 3. Grave 10-30 segundos da sua voz
# 4. Nomeie (ex: "Raquel 9Pilla")
# 5. Copie o Voice ID que aparecer
# 6. Coloque aqui no ELEVENLABS_VOICE_ID

# ═══════════════════════════════════════════════════════════════
# 4. HEYGEN — Avatar Video Generation
# ═══════════════════════════════════════════════════════════════
# Cria vídeos com avatar falando seu script
# API Key: sk_V2_hgu_kkX2jmyuQzW_9R8ocwO4rBLzHX0mrIyQwKAJWLAGrJjW
# Avatar ID (realista Raquel): 351538dd8eea417882a312681f2168d9
# ⚠️ US$ 15 em créditos - Use com sabedoria!
# Só cria avatar APÓS aprovação por Raquel (cost optimization)
HEYGEN_API_KEY=sk_V2_hgu_kkX2jmyuQzW_9R8ocwO4rBLzHX0mrIyQwKAJWLAGrJjW
HEYGEN_AVATAR_ID=351538dd8eea417882a312681f2168d9

# ═══════════════════════════════════════════════════════════════
# 5. Z-API — WhatsApp Broadcast Integration
# ═══════════════════════════════════════════════════════════════
# Envia notificações para Turma 9Pilla quando shorts é publicado
# Instance ID: 3F11BDD3D23071C40CFC9EED2DF277BD
# Token: D06BC58B1E9B2833DB10EBF3
ZAPI_INSTANCE_ID=3F11BDD3D23071C40CFC9EED2DF277BD
ZAPI_API_TOKEN=D06BC58B1E9B2833DB10EBF3

# ═══════════════════════════════════════════════════════════════
# 6. TELEGRAM — Script Approval Workflow
# ═══════════════════════════════════════════════════════════════
# Bot envia scripts para Raquel aprovar via Telegram
# 1. Vá para: https://t.me/BotFather
# 2. Crie novo bot: /newbot
# 3. Copie o TOKEN
# 4. Envie /start ao bot novo
# 5. Execute: curl https://api.telegram.org/bot{TOKEN}/getUpdates
# 6. Copie o chat_id de Raquel
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# ═══════════════════════════════════════════════════════════════
# 7. MANYCHAT — Funnel Automation
# ═══════════════════════════════════════════════════════════════
# Automação de flows: Welcome, Morning Call, Upsells
# API Key: 11058963:93a19ff0c8e75129c2d9303960e974dd
MANYCHAT_API_KEY=11058963:93a19ff0c8e75129c2d9303960e974dd

# ═══════════════════════════════════════════════════════════════
# 8. YOUTUBE — Publishing Credentials
# ═══════════════════════════════════════════════════════════════
# Google OAuth2 credentials para publicar Shorts
# Setup: https://console.cloud.google.com
# 1. Create project
# 2. Enable YouTube Data API
# 3. Create OAuth2 desktop app credentials
# 4. Download credentials.json
YOUTUBE_CREDENTIALS_PATH=./credentials/youtube_credentials.json
YOUTUBE_CHANNEL_ID=YOUR_CHANNEL_ID

# ═══════════════════════════════════════════════════════════════
# 9. DATABASE — PostgreSQL (Opcional)
# ═══════════════════════════════════════════════════════════════
# Para tracking de jobs, logs, feedback
# Em desenvolvimento: usa SQLite local
# Em produção: configure PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/9pilla

# ═══════════════════════════════════════════════════════════════
# 10. SYSTEM — General Configuration
# ═══════════════════════════════════════════════════════════════
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Diretório para salvar vídeos gerados localmente
OUTPUT_DIR=./output/videos

# Diretório para cache de thumbnails, etc
CACHE_DIR=./cache

# Modo de teste (não publica realmente, apenas simula)
DRY_RUN=false

# ═══════════════════════════════════════════════════════════════
# VALIDATION CHECKLIST
# ═══════════════════════════════════════════════════════════════
# Antes de rodar a pipeline, confirme:
# ✅ BRAPI_API_KEY preenchida
# ✅ OLLAMA_BASE_URL rodando localmente (ollama serve)
# ✅ ELEVENLABS_API_KEY + VOICE_ID configurados (após clonar voz)
# ✅ HEYGEN_API_KEY preenchida
# ✅ ZAPI credentials corretos
# ✅ TELEGRAM_BOT_TOKEN + CHAT_ID configurados
# ✅ MANYCHAT_API_KEY preenchida (opcional)
#
# DEPOIS: python orchestrator.py --validate
